{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "paths": {
      "@fhevm/sdk": ["../js-sdk/src/_types/index.d.ts"],
      "@fhevm/sdk/*": ["../js-sdk/src/_types/*", "../js-sdk/src/_types/core/*"]
    }
  },
  "include": ["./scripts", "./test", "./hardhat.config.ts"]
}
