{
  "name": "js-sdk-hardhat-test",
  "version": "1.0.0",
  "private": true,
  "description": "Hardhat workspace package consuming @fhevm/sdk",
  "scripts": {
    "prettier:check": "prettier --check \"**/*.{js,json,md,sol,ts,yml}\"",
    "prettier:write": "prettier --write \"**/*.{js,json,md,sol,ts,yml}\"",
    "tsc": "tsc --noEmit -p tsconfig.hardhat.json",
    "compile": "hardhat compile --network localhost --tsconfig tsconfig.hardhat.json",
    "example": "hardhat run scripts/example.ts --network hardhat --tsconfig tsconfig.hardhat.json",
    "test": "hardhat test --network localhost --tsconfig tsconfig.hardhat.json"
  },
  "dependencies": {
    "@fhevm/solidity": "*",
    "@fhevm/sdk": "*",
    "@openzeppelin/contracts": "^5.3.0",
    "encrypted-types": "^0.0.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.0.0",
    "ethers": "^6.15.0",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.4"
  }
}
