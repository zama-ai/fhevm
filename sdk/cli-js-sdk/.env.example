# --- Host-chain RPC endpoints (per network) ----------------------------------
MAINNET_RPC_URL=https://eth.drpc.org
SEPOLIA_RPC_URL=https://sepolia.drpc.org
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# --- SDK / relayer auth (optional) -------------------------------------------
ZAMA_FHEVM_API_KEY=

# --- Wallet credentials -------------------------------------------------------
# CLI flows use PRIVATE_KEY or MNEMONIC.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
MNEMONIC=

# Delegated user-decrypt (CLI): the encrypted-data owner granting delegation.
DELEGATOR_PRIVATE_KEY=0xANOTHER_PRIVATE_KEY
DELEGATOR_MNEMONIC=
