# --- Host-chain RPC endpoints (per network) ----------------------------------
MAINNET_RPC_URL=https://eth.drpc.org
SEPOLIA_RPC_URL=https://sepolia.drpc.org
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# --- SDK / relayer auth (optional) -------------------------------------------
ZAMA_FHEVM_API_KEY=

# --- Wallet credentials -------------------------------------------------------
# Normal CLI flows and load-test pool owners use PRIVATE_KEY or MNEMONIC.
# For load tests, prefer MNEMONIC: HD wallet lanes allow parallel transactions.
# PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# MNEMONIC="your twelve or twenty-four word mnemonic"

# Normal CLI delegated user-decrypt only: credentials for the encrypted-data
# owner (delegator). The delegate still uses PRIVATE_KEY or MNEMONIC above.
# DELEGATOR_PRIVATE_KEY=0xYOUR_DELEGATOR_PRIVATE_KEY
# DELEGATOR_MNEMONIC="your delegator mnemonic"

# Load-test delegated pools only: a distinct sign-only delegate account used
# when MNEMONIC is not set. This is not the normal CLI's DELEGATOR_PRIVATE_KEY.
# DELEGATE_PRIVATE_KEY=0xYOUR_DELEGATE_PRIVATE_KEY

# --- Load-test configuration --------------------------------------------------
# All values are optional. CLI flags take precedence over these variables.
# Leave overrides commented to retain configured network and command defaults.

# Network and primary relayer overrides.
# LOAD_TEST_NETWORK=testnet
# LOAD_TEST_RELAYER_URL=https://relayer.example.com
# LOAD_TEST_RELAYER_API_PREFIX=/v2

# Optional candidate relayer for paired A/B runs.
# LOAD_TEST_RELAYER_B_URL=https://candidate-relayer.example.com
# LOAD_TEST_RELAYER_B_API_PREFIX=/v2

# Artifact directory and optional relayer config snapshots included in reports.
# LOAD_TEST_DATA_DIR=.load-test
# LOAD_TEST_RELAYER_CONFIG=/path/to/primary-relayer-config.toml
# LOAD_TEST_RELAYER_B_CONFIG=/path/to/candidate-relayer-config.toml
