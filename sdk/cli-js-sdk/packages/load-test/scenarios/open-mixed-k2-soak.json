{
  "name": "open-mixed-k2-soak",
  "description": "Open model: 4 rps for 4 hours, split evenly between user-decrypt and public-decrypt with k=2.",
  "flows": [
    {
      "flow": "user-decrypt",
      "weight": 1
    },
    {
      "flow": "public-decrypt",
      "weight": 1,
      "handlesPerRequest": 2
    }
  ],
  "shape": {
    "kind": "constant",
    "rps": 4,
    "durationSec": 14400
  },
  "thresholds": {
    "maxErrorRate": 0.01,
    "maxVerifyFailures": 0,
    "perFlow": {}
  }
}
