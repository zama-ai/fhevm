{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fhevm.dev/schemas/js-sdk/multi-wasm-matrix.schema.json",
  "title": "JS SDK multi-WASM browser test matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "defaults", "supportedVersionPairs", "assetUrlSets"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "supportedVersionPairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/versionPair"
      }
    },
    "assetUrlSets": {
      "$ref": "#/$defs/assetUrlSets"
    }
  },
  "$defs": {
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roundTrip"],
      "properties": {
        "roundTrip": {
          "$ref": "#/$defs/roundTrip"
        }
      }
    },
    "versionPair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tfhe", "kms"],
      "properties": {
        "tfhe": {
          "type": "string"
        },
        "kms": {
          "type": "string"
        },
        "cdns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "assetUrlSets": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/assetUrlSet"
      },
      "minProperties": 1,
      "required": ["local"],
      "properties": {
        "local": {
          "$ref": "#/$defs/assetUrlSet"
        }
      }
    },
    "assetUrlSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tfheWasm", "tfheWorker", "kmsWasm"],
      "properties": {
        "tfheWasm": {
          "type": "string"
        },
        "tfheWorker": {
          "type": "string"
        },
        "kmsWasm": {
          "type": "string"
        }
      }
    },
    "roundTrip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clearType", "contractMethod", "makePublic", "value"],
      "properties": {
        "clearType": {
          "enum": ["bool", "uint8", "uint16", "uint32", "uint64", "uint128", "uint256", "address"]
        },
        "contractMethod": {
          "enum": [
            "setEbool",
            "setEuint8",
            "setEuint16",
            "setEuint32",
            "setEuint64",
            "setEuint128",
            "setEuint256",
            "setEaddress"
          ]
        },
        "makePublic": {
          "type": "boolean"
        },
        "value": {
          "type": ["boolean", "integer", "string"]
        }
      }
    }
  }
}
