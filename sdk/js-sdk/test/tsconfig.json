  "include": [".", "../src"],
  "exclude": ["standalone"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "rootDir": "..",
    "paths": {
      "~test/*": ["./src/*"],
      "fhevm": ["./../src/index.ts"],
      "fhevm/ethers": ["./../src/ethers/index.ts"],
      "fhevm/viem": ["./../src/viem/index.ts"],
