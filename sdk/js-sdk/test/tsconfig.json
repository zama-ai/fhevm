      "@fhevm/sdk/viem": ["./../src/viem/index.ts"],
      "@fhevm/sdk/chains": ["./../src/core/chains/index.ts"],
      "@fhevm/sdk/actions/base": ["./../src/core/actions/base/index.ts"],
      "@fhevm/sdk/actions/chain": ["./../src/core/actions/chain/index.ts"],
      "@fhevm/sdk/actions/decrypt": ["./../src/core/actions/decrypt/index.ts"],
      "@fhevm/sdk/actions/encrypt": ["./../src/core/actions/encrypt/index.ts"],
