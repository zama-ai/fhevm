{
  "name": "@fhevm/sdk-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:prod",
    "build:dev": "BUILD_PROFILE=dev npm run build:profile",
    "build:prod": "BUILD_PROFILE=prod npm run build:profile",
    "build:profile": "npm run clean && npm run codegen:loaders && npm run codegen:solana:check && npm run prettier:check && npm run prettier:ext && npm run lint && npm run build:cjs && npm run build:esm && npm run build:types && npm run build:tests",
    "build:tests": "tsc --project ./test/tsconfig.json --noEmit",
    "build:cjs": "tsc --project ./tsconfig.build.cjs.json --module commonjs --moduleResolution node --outDir ./src/_cjs --removeComments --verbatimModuleSyntax false && printf '{\"type\":\"commonjs\"}' > ./src/_cjs/package.json && npm run build:cjs:wasm",
    "build:cjs:wasm:legacy": "node -e \"require('fs').cpSync('src/wasm','src/_cjs/wasm',{recursive:true})\"",
    "build:cjs:wasm": "node scripts/build/build-cjs-wasm.mjs",
    "build:esm": "tsc --project ./tsconfig.build.esm.json --outDir ./src/_esm && printf '{\"type\": \"module\",\"sideEffects\":false}' > ./src/_esm/package.json && npm run build:esm:wasm",
    "build:esm:wasm": "node scripts/build/build-esm-wasm.mjs",
    "codegen:loaders": "node scripts/build/codegen-loaders.mjs",
    "codegen:loaders:dev": "BUILD_PROFILE=dev node scripts/build/codegen-loaders.mjs",
    "codegen:loaders:prod": "BUILD_PROFILE=prod node scripts/build/codegen-loaders.mjs",
    "codegen:loaders:check": "node scripts/build/codegen-loaders.mjs --check",
    "codegen:solana": "node scripts/build/codegen-solana-confidential-token.mjs",
    "codegen:solana:check": "node scripts/build/codegen-solana-confidential-token.mjs --check",
    "prepublishOnly": "npm run build:prod",
    "wasm:install": "node scripts/wasm/install-from-manifest.mjs",
    "build:types": "tsc --project ./tsconfig.build.esm.json --declarationDir ./src/_types --emitDeclarationOnly --declaration --declarationMap && npm run build:types:wasm",
    "build:types:wasm": "node scripts/build/build-types-wasm.mjs",
    "clean": "rm -rf *.tsbuildinfo src/*.tsbuildinfo src/_esm src/_cjs src/_types",
    "size-limit": "size-limit",
    "lint": "eslint --config ./eslint.config.js && tsc -b ./tsconfig.json --noEmit",
    "lint:jsdoc": "eslint --config eslint.jsdoc.config.js",
    "prettier:ext": "./scripts/prettier/check-file-casing.sh && ./scripts/prettier/check-import-order.sh ./scripts/prettier/check-no-leading-comment.sh",
    "prettier:check": "prettier --check \"**/*.{js,json,md,sol,ts,yml}\"",
    "prettier:write": "prettier --write \"**/*.{js,json,md,sol,ts,yml}\"",
    "test:unit": "npx vitest run --config src/vitest.config.ts --coverage",
    "test:browser": "npx playwright test --config test/browser/playwright.config.ts",
    "test:browser:manual": "npx vite --config test/browser/vite.config.ts",
    "test:browser-ui": "npx vite --config test/browser-ui/vite.config.ts",
    "test:localstack:multi-wasm:full": "node test/multi-wasm/run.mjs",
    "test:fast:testnet": "CHAIN=sepolia npx vitest run --config test/fheTest/vitest.config.ts --exclude '**/**.slow.test.ts' test/fheTest/ethers test/fheTest/viem",
    "test:fast:devnet": "CHAIN=devnet npx vitest run --config test/fheTest/vitest.config.ts --exclude '**/**.slow.test.ts' test/fheTest/ethers test/fheTest/viem",
    "test:full:testnet": "CHAIN=sepolia npx vitest run --config test/fheTest/vitest.config.ts test/fheTest/ethers test/fheTest/viem",
    "test:full:devnet": "CHAIN=devnet npx vitest run --config test/fheTest/vitest.config.ts test/fheTest/ethers test/fheTest/viem",
    "test:examples:testnet": "tsx ./examples/node-ethers/test-run.ts && tsx ./examples/node-viem/test-run.ts",
    "test:localstack": "./test/scripts/localstack-run-tests.sh",
    "test:localstack:v11": "./test/scripts/localstack-run-tests.sh --chain localstack_v11 --fhevm-cli-profile v0.11.0-mainnet.json",
    "test:localstack:v12": "./test/scripts/localstack-run-tests.sh --chain localstack_v12 --fhevm-cli-profile v0.12.0-testnet.json",
    "test:localstack:v13": "./test/scripts/localstack-run-tests.sh --chain localstack_v13 --fhevm-cli-profile v0.13.0.json",
    "test:localcleartext:v12": "./test/scripts/localcleartext-run-tests.sh --foundry-profile=v12",
    "test:localcleartext:v13": "./test/scripts/localcleartext-run-tests.sh --foundry-profile=v13",
    "test:localcleartext:pack:v12": "./test/scripts/rebuild_sdk_and_pack.sh --build-profile=prod && ./test/scripts/localcleartext-run-tests.sh --use-pack --foundry-profile=v12",
    "test:localcleartext:pack:v13": "./test/scripts/rebuild_sdk_and_pack.sh --build-profile=prod && ./test/scripts/localcleartext-run-tests.sh --use-pack --foundry-profile=v13",
    "test": "npm run test:unit && npm run test:localcleartext:pack:v12 && npm run test:localcleartext:pack:v13 && npm run test:browser",
    "dod": "node test/scripts/dod.mjs",
    "dod:full": "node test/scripts/dod.mjs --full",
    "version": "node ./scripts/generate-version.cjs",
    "start:localcleartext:v12": "./test/scripts/fhevm-anvil.sh --ethlib none --foundry-profile=v12",
    "start:localcleartext:v13": "./test/scripts/fhevm-anvil.sh --ethlib none --foundry-profile=v13"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "1.5.1",
    "@codama/renderers-js": "2.3.0",
    "@eslint/js": "^10.0.1",
    "@noble/curves": "2.0.1",
    "@noble/hashes": "2.0.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-big-lib": "^12.0.1",
    "@solana/kit": "6.10.0",
    "@solana/program-client-core": "6.10.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "codama": "1.8.0",
    "eslint": "^10.0.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "ethers": "^6.16.0",
    "prettier": "^3.6.2",
    "size-limit": "^12.0.1",
    "test": "vitest -c ./test/vitest.config.ts",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "viem": "^2.46.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wasm-feature-detect": "^1.8.0"
  },
  "imports": {
    "#wasm/baseUrl": {
      "import": "./src/wasm/wasmBaseUrl.js",
      "require": "./src/wasm/wasmBaseUrl.cjs"
    }
  },
  "size-limit": [
    {
      "name": "import * from '@fhevm/sdk/actions/base'",
      "path": "./src/_esm/core/actions/base/index.js",
      "limit": "15 kB",
      "import": "*"
    },
    {
      "name": "import * from '@fhevm/sdk/actions/host'",
      "path": "./src/_esm/core/actions/host/index.js",
      "limit": "10 kB",
      "import": "*"
    },
    {
      "name": "import * from '@fhevm/sdk/actions/chain'",
      "path": "./src/_esm/core/actions/chain/index.js",
      "limit": "12 kB",
      "import": "*"
    },
    {
      "name": "import * from '@fhevm/sdk/actions/encrypt'",
      "path": "./src/_esm/core/actions/encrypt/index.js",
      "limit": "13 kB",
      "import": "*"
    },
    {
      "name": "import * from '@fhevm/sdk/actions/decrypt'",
      "path": "./src/_esm/core/actions/decrypt/index.js",
      "limit": "12 kB",
      "import": "*"
    },
    {
      "name": "import { createFhevmBaseClient } from '@fhevm/sdk/ethers'",
      "path": "./src/_esm/ethers/clients/createFhevmBaseClient.js",
      "limit": "50 kB",
      "import": "{ createFhevmBaseClient }"
    },
    {
      "name": "import { createFhevmDecryptClient } from '@fhevm/sdk/ethers'",
      "path": "./src/_esm/ethers/clients/createFhevmDecryptClient.js",
      "limit": "60 kB",
      "import": "{ createFhevmDecryptClient }",
      "ignore": [
        "node:buffer",
        "node:fs/promises",
        "node:url"
      ]
    },
    {
      "name": "import { createFhevmEncryptClient } from '@fhevm/sdk/ethers'",
      "path": "./src/_esm/ethers/clients/createFhevmEncryptClient.js",
      "limit": "82 kB",
      "import": "{ createFhevmEncryptClient }",
      "ignore": [
        "node:buffer",
        "node:fs/promises",
        "node:url"
      ]
    },
    {
      "name": "import { createFhevmClient } from '@fhevm/sdk/ethers'",
      "path": "./src/_esm/ethers/clients/createFhevmClient.js",
      "limit": "86 kB",
      "import": "{ createFhevmClient }",
      "ignore": [
        "node:buffer",
        "node:fs/promises",
        "node:url"
      ]
    },
    {
      "name": "import * from from '@fhevm/sdk/ethers'",
      "path": "./src/_esm/ethers/index.js",
      "limit": "92 kB",
      "import": "*",
      "ignore": [
        "node:buffer",
        "node:fs/promises",
        "node:url"
      ]
    }
  ],
  "overrides": {
    "//": "@types/eslint-scope@3.7.7 has a broken writeExpr typing that fails with skipLibCheck:false. Pin to 3.7.6.",
    "webpack": {
      "@types/eslint-scope": "3.7.6"
    }
  },
  "engines": {
    "node": ">=22.0"
  }
}
