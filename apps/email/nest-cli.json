{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "../config/*.yaml",
        "outDir": "./dist/config"
      },
      {
        "include": "../templates/*.ejs",
        "outDir": "./dist/templates"
      }
    ]
  }
}
