<%- include('partials/start') -%>
      <%- include('partials/header', { title: 'Confirm your email' }) -%>
      <div class="content">
        <p>
          We received a request to create an account associated with this email
          address.
        </p>
        <p>To confirm your email, please click the link below:</p>
      </div>
      <%- include('partials/button', { href: frontendUrl + 'validate/' + token, text: 'Confirm Email' }) -%>
      <div class="content">
        <p>
          If you did not sign up, please ignore this message. This link will
          expire in 24 hours for your security.
        </p>
      </div>
<%- include('partials/end') -%>  
