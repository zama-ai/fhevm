{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE public_decrypt_req\n            SET req_status = 'in_flight'\n            WHERE id = (\n                SELECT id\n                FROM public_decrypt_req\n                WHERE req_status = 'queued'\n                ORDER BY created_at ASC\n                LIMIT 1\n                FOR UPDATE SKIP LOCKED\n            )\n            RETURNING\n                id,\n                ext_req_id,\n                internal_decryption_id,\n                gw_decryption_id,\n                req,\n                res,\n                req_status AS \"req_status: _\",\n                tx_hash,\n                err_reason,\n                created_at,\n                updated_at\n            ",
