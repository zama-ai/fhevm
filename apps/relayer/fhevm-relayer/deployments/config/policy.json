{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "s3:ListBucket",
          "s3:GetObject",
          "s3:PutObject",
          "s3:DeleteObject"
        ],
        "Resource": [
          "arn:aws:s3:::ct64",
          "arn:aws:s3:::ct64/*",
          "arn:aws:s3:::ct128",
          "arn:aws:s3:::ct128/*"
        ]
      }
    ]
  }
  