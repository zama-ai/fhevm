{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "../config/*.yaml",
        "outDir": "./dist/config"
      },
      {
        "include": "../generated/**",
        "outDir": "./dist/generated"
      }
    ],
    "deleteOutDir": true
  }
}
