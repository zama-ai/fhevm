generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamStatus {
  ANONYMOUS
  ACTIVE
}

model Invitation {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique()
  usedAt    DateTime?
  expiresAt DateTime
  updatedAt DateTime  @default(now())
  createdAt DateTime  @default(now())

  @@index([token])
}

model User {
  id        String   @id()
  email     String   @unique
  password  String
  teams     Team[]
  updatedAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(uuid())
  name      String
  users     User[]
  updatedAt DateTime @default(now())
  createdAt DateTime @default(now())
}
