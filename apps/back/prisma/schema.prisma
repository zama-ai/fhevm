// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output into a separate subdirectory so multiple schemas can be used in a monorepo
  // this make the import path `@prisma/client/back` instead of `@prisma/client`
  // output   = "../../../node_modules/@prisma/client/back"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DappStatus {
  DRAFT
  DEPLOYING
  LIVE
  ARCHIVED
  DELETED
}

model Invitation {
  id        String    @id
  email     String    @unique
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())

  @@index([token])
}

model User {
  id        String   @id
  email     String   @unique
  password  String
  name      String
  teams     Team[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id
  name      String
  users     User[]
  dapps     Dapp[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Dapp {
  id        String     @id
  name      String
  address   String?
  status    DappStatus @default(DRAFT)
  teamId    String
  team      Team       @relation(fields: [teamId], references: [id])
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())
}
