generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Invitation {
  id        String    @id
  email     String    @unique
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())

  @@index([token])
}

model User {
  id        String   @id
  email     String   @unique
  password  String
  name      String
  teams     Team[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id
  name      String
  users     User[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
