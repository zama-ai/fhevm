{
  "name": "@zws/back",
  "private": true,
  "version": "0.0.1",
  "description": "nestjs + prisma + graphql backend",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "NODE_ENV=local nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "RUN_MODE=test vitest run --pass-with-no-tests",
    "test:watch": "RUN_MODE=test vitest",
    "test:cov": "RUN_MODE=test vitest run --coverage",
    "test:debug": "RUN_MODE=test vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "RUN_MODE=test vitest run --config ./vitest.e2e.config.mts --pass-with-no-tests",
    "test:e2e:watch": "RUN_MODE=test vitest --config ./vitest.e2e.config.mts"
  },
  "dependencies": {
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "dotenv": "16.4.7",
    "messages": "workspace:*",
    "nestjs-pino": "catalog:",
    "pino": "catalog:",
    "pino-http": "catalog:",
    "pino-pretty": "catalog:",
    "reflect-metadata": "0.1.13",
    "utils": "workspace:*",
    "yaml": "2.8.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "@nestjs/cli": "11.0.7",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@suites/di.nestjs": "3.0.1",
    "@suites/doubles.vitest": "3.0.1",
    "@suites/types.common": "^3.0.0",
    "@suites/types.doubles": "^3.0.0",
    "@suites/unit": "3.0.1",
    "@swc/core": "1.10.1",
    "@types/express": "5.0.2",
    "@types/ms": "2.1.0",
    "@types/node": "22.14.0",
    "@types/supertest": "6.0.0",
    "@typescript-eslint/eslint-plugin": "8.0.0",
    "@typescript-eslint/parser": "8.0.0",
    "@vitest/coverage-v8": "3.2.1",
    "dotenv": "16.4.7",
    "eslint": "catalog:",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "globals": "catalog:",
    "prettier": "catalog:",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-loader": "9.4.3",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "imports": {
    "#*": "./dist/src/*"
  }
}
