{
  "name": "@zws/back",
  "private": true,
  "version": "0.0.1",
  "description": "nestjs + prisma + graphql backend",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm run copy:generated && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./vitest.e2e.config.mts",
    "test:e2e:watch": "vitest --config ./vitest.e2e.config.mts",
    "prisma:generate": "pnpx prisma generate",
    "prisma:migrate": "pnpx prisma migrate deploy",
    "copy:generated": "cpx 'generated/**' 'dist/generated'",
    "prestart": "pnpx prisma migrate dev"
  },
  "dependencies": {
    "@apollo/server": "4.11.3",
    "@aws-sdk/client-sqs": "3.816.0",
    "@nestjs/apollo": "catalog:",
    "@nestjs/common": "catalog:",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/graphql": "catalog:",
    "@nestjs/jwt": "catalog:",
    "@nestjs/passport": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@prisma/client": "catalog:",
    "@ssut/nestjs-sqs": "catalog:",
    "bcryptjs": "2.4.3",
    "bullmq": "5.41.9",
    "dotenv": "16.4.7",
    "graphql": "16.10.0",
    "graphql-query-complexity": "1.0.0",
    "graphql-redis-subscriptions": "2.7.0",
    "graphql-subscriptions": "3.0.0",
    "graphql-ws": "6.0.3",
    "ioredis": "5.6.0",
    "messages": "workspace:*",
    "nanoid": "5.0.9",
    "nestjs-cls": "catalog:",
    "nestjs-pino": "catalog:",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pino": "catalog:",
    "pino-http": "catalog:",
    "pino-pretty": "catalog:",
    "reflect-metadata": "0.1.13",
    "rimraf": "6.0.1",
    "utils": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "@nestjs/cli": "11.0.7",
    "@nestjs/schematics": "catalog:",
    "@nestjs/testing": "catalog:",
    "@suites/di.nestjs": "3.0.1",
    "@suites/doubles.vitest": "3.0.1",
    "@suites/unit": "3.0.1",
    "@swc/core": "1.10.1",
    "@testcontainers/localstack": "10.16.0",
    "@testcontainers/postgresql": "10.16.0",
    "@testcontainers/redis": "10.17.2",
    "@types/bcryptjs": "2.4.6",
    "@types/express": "5.0.2",
    "@types/node": "22.14.0",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.0",
    "@typescript-eslint/eslint-plugin": "8.0.0",
    "@typescript-eslint/parser": "8.0.0",
    "@vitest/coverage-v8": "2.1.8",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-vitest": "6.1.1",
    "cpx": "1.5.0",
    "dotenv": "16.4.7",
    "eslint": "catalog:",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-prettier": "5.0.0",
    "globals": "15.11.0",
    "prettier": "catalog:",
    "prisma": "catalog:",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-loader": "9.4.3",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "imports": {
    "#prisma/client": "./dist/generated/client",
    "#*": "./dist/src/*"
  }
}
