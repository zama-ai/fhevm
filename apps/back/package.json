{
  "name": "@zws/back",
  "private": true,
  "version": "0.0.1",
  "description": "nestjs + prisma + graphql backend",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm run copy:generated && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./vitest.e2e.config.mts",
    "test:e2e:watch": "vitest --config ./vitest.e2e.config.mts",
    "prisma:generate": "pnpx prisma generate",
    "copy:generated": "cpx 'generated/**' 'dist/generated'",
    "prestart": "pnpx prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.699.0",
    "@aws-sdk/client-sqs": "^3.699.0",
    "@nestjs/apollo": "^12.2.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/graphql": "^12.2.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "graphql-redis-subscriptions": "^2.7.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^6.0.2",
    "ioredis": "^5.4.2",
    "messages": "workspace:*",
    "nanoid": "^5.0.9",
    "nestjs-cls": "^4.5.0",
    "nestjs-pino": "catalog:",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "catalog:",
    "pino-http": "catalog:",
    "pino-pretty": "catalog:",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^6.0.1",
    "sqs": "workspace:*",
    "utils": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.10",
    "@swc/core": "^1.10.1",
    "@testcontainers/localstack": "^10.16.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@testcontainers/redis": "^10.17.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^6.1.1",
    "cpx": "^1.5.0",
    "dotenv": "^16.4.7",
    "eslint": "catalog:",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.11.0",
    "graphql-tag": "^2.12.6",
    "prettier": "catalog:",
    "prisma": "5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "supertest-graphql": "^1.1.4",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:",
    "vitest-mock-extended": "^2.0.2"
  },
  "imports": {
    "#prisma/client": "./dist/generated/client",
    "#*": "./dist/src/*"
  }
}
