{
  "name": "@zws/front",
  "private": true,
  "version": "0.0.1",
  "description": "react + vite + graphql frontend",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "start": "vite --host",
    "build": "tsc -b && vite build --logLevel error",
