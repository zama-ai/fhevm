    "date-fns": "^4.1.0",
    "formik": "^2.4.6",
    "graphql": "^16.9.0",
    "lucide-react": "^0.461.0",
    "next-themes": "^0.4.3",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.1.3",
    "recharts": "^2.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@graphql-codegen/cli": "^5.0.3",
