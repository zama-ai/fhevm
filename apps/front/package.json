{
  "name": "@zws/front",
  "private": true,
  "version": "0.0.1",
  "description": "react + vite + graphql frontend",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "start": "vite --host",
    "build": "tsc -b && vite build --logLevel error",
    "lint": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run --pass-with-no-tests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.26.0",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "9.13.0",
    "@fontsource-variable/archivo": "^5.2.6",
    "@fontsource-variable/inter": "^5.2.6",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "@vitejs/plugin-react-swc": "3.7.1",
    "dotenv": "16.4.7",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "eslint-plugin-storybook": "0.11.2",
    "globals": "catalog:",
    "jsdom": "26.0.0",
    "typescript": "catalog:",
    "typescript-eslint": "8.11.0",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "5.1.3",
    "vitest": "catalog:"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
