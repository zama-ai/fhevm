{
  "name": "@zama-fhe/oracle-solidity",
  "version": "0.1.0",
  "description": "Oracle Solidity smart contract for public decryption",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "pnpm hardhat compile && pnpm hardhat test --network hardhat",
    "lint": "pnpm run lint:sol && pnpm run lint:ts && pnpm run prettier:check",
    "lint:ts": "eslint --ignore-path ./.eslintignore --ext .js,.ts .",
    "prettier:check": "prettier --check \"**/*.{js,json,md,sol,ts,yml}\"",
    "prettier": "prettier --write \"**/*.{js,json,md,sol,ts,yml}\""
  },
  "author": "",
  "license": "BSD-3-Clause",
  "dependencies": {
    "@fhevm/solidity": "^0.8.0",
    "@openzeppelin/contracts": "5.1.0",
    "@openzeppelin/contracts-upgradeable": "5.1.0",
    "@openzeppelin/foundry-upgrades": "^0.3.8",
    "@openzeppelin/hardhat-upgrades": "3.5.0",
    "ethers": "~6.15.0",
    "hardhat": "^2.26.3",
    "hardhat-deploy": "^0.11.45",
    "hardhat-ignore-warnings": "^0.2.12"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "prettier": "^3.6.2",
    "prettier-plugin-solidity": "^1.4.3"
  },
  "engines": {
    "node": ">=22"
  }
}
