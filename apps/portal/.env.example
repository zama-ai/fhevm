# Auth0 Configuration
# Get these values from your Auth0 Dashboard (https://manage.auth0.com)

# Your Auth0 domain (e.g., your-tenant.auth0.com or your-tenant.us.auth0.com)
AUTH0_DOMAIN=your-domain.auth0.com

# Your Auth0 application's Client ID
AUTH0_CLIENT_ID=your-client-id

# Your Auth0 application's Client Secret
AUTH0_CLIENT_SECRET=your-client-secret

# Optional: Your Auth0 API identifier/audience (only needed if calling Auth0 APIs)
AUTH0_AUDIENCE=

# Session Secret (generate a random string for production)
# You can generate one with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-at-least-32-characters-long

# Moesif Configuration
# Only change to V1 if you're using an old version of Moesif monetization data
MOESIF_MONETIZATION_VERSION="V2"
MOESIF_APPLICATION_ID=<moesief-application-id>
MOESIF_MANAGEMENT_TOKEN=<moesief-management-token>
MOESIF_TEMPLATE_WORKSPACE_ID_LIVE_EVENT_LOG=<live-event-log-id>
MOESIF_TEMPLATE_WORKSPACE_ID_TIME_SERIES=<time-series-id>
MOESIF_PLANS_CACHE_SECONDS=300

# Stripe Configuration
# The private API key for your Stripe account
STRIPE_SECRET_KEY=your-stripe-api-key
# The publishable API key for your Stripe account (used in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Stripe customer portal link
VITE_STRIPE_MANAGEMENT_URL=your-stripe-customer-portal-url
PORTAL_APP_URL=http://localhost:5173

# KONG Configuration
KONG_URL=https://your-kong-admin-url.com
KONG_ADMIN_TOKEN=your-kong-admin-token