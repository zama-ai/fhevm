# Copy this file as `.env` and save your current configuration.
APP__PORT=3001
APP__AWS__ACCESS_KEY_ID=test
APP__AWS__SECRET_ACCESS_KEY=test
APP__AWS__REGION=eu-central-1
APP__AWS__ENDPOINT_URL=http://console-aws:4566
APP__AWS__ENDPOINT=http://console-aws:4566
APP__AWS__BACK_QUEUE_URL=http://console-aws:4566/000000000000/back-queue
APP__AWS_ORCHESTRATOR_QUEUE_URL=http://console-aws:4566/000000000000/orchestrator-queue
APP__AWS_WEB3_QUEUE_URL=http://console-aws:4566/000000000000/web3-queue
APP__AWS_RELAYER_QUEUE_URL=http://console-aws:4566/000000000000/relayer-queue
APP__DB__URL="postgresql://postgres:postgres@console-postgres:5432/console?schema=orchestrator"
DATABASE_URL="postgresql://postgres:postgres@console-postgres:5432/console?schema=orchestrator"
# AWS_EMAIL_QUEUE_URL=http://console-aws:4566/000000000000/email-queue
# WEB3_CHAIN_IDS="123456,11155111"
WEB3_CHAIN_IDS="123456"
WEB3_EVERY="1 hour"

APP__REDIS__HOST=console-redis
APP__REDIS__PORT=6379
