meta {
  name: Get All API Keys
  type: graphql
  seq: 5
}

post {
  url: http://localhost:3000/graphql
  body: graphql
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

body:graphql {
  query getAllApiKeys($dappId: ID!) {
    dapp(input: { id: $dappId }) {
      apiKeys {
        id
        name
        description
      }
    }
  }
  
}

body:graphql:vars {
  {
    "dappId": "{{dappId}}"
  }
}
