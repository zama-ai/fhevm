meta {
  name: Login
  type: graphql
  seq: 3
}

post {
  url: http://localhost:3000/graphql
  body: graphql
  auth: none
}

body:graphql {
  mutation login($email: String!, $password: String!) {
    login(input: {
      email: $email
      password: $password
    }) {
      token
      
    }
  }
}

body:graphql:vars {
  {
    "password": "ChangeMe",
    "email": "{{email}}"
  }
}
