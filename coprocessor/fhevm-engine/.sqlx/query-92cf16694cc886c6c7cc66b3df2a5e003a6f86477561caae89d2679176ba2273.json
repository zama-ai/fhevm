  "query": "\n        SELECT handle as \"handle!\",\n               key_id_gw as \"key_id_gw!\",\n               transaction_id,\n               ciphertext,\n               ciphertext128,\n               ciphertext128_format as \"ciphertext128_format!\"\n         FROM ciphertext_digest\n         WHERE handle = $1\n           AND s3_format_version = $2\n           AND (ciphertext IS NOT NULL OR ciphertext128 IS NOT NULL)\n        ",
