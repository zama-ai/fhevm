{
  "name": "@fhevm/lz-wiring",
  "version": "0.1.0",
  "description": "Isolated LayerZero V2 wiring workspace for ConfidentialBridge. Uses ethers v5 + the official @layerzerolabs/toolbox-hardhat, avoiding the ethers v6 / zksync-web3 incompatibility that prevents `lz:oapp:wire` from loading in the parent host-contracts project.",
  "private": true,
  "scripts": {
    "prewire": "ts-node scripts/sync-deployments.ts",
    "wire": "pnpm prewire && hardhat lz:oapp:wire --oapp-config layerzero.config.ts",
    "wire:dry": "pnpm prewire && hardhat lz:oapp:wire --oapp-config layerzero.config.ts --dry-run",
    "peers:get": "pnpm prewire && hardhat lz:oapp:peers:get --oapp-config layerzero.config.ts",
    "config:get": "pnpm prewire && hardhat lz:oapp:config:get --oapp-config layerzero.config.ts",
    "enforced-opts:get": "pnpm prewire && hardhat lz:oapp:enforced-opts:get --oapp-config layerzero.config.ts"
  },
  "resolutions": {
    "ethers": "^5.7.2"
  },
  "devDependencies": {
    "@layerzerolabs/lz-definitions": "^3.0.148",
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.148",
    "@layerzerolabs/lz-v2-utilities": "^3.0.148",
    "@layerzerolabs/metadata-tools": "^3.0.0",
    "@layerzerolabs/oapp-evm": "^0.4.1",
    "@layerzerolabs/toolbox-hardhat": "~0.6.13",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@safe-global/safe-core-sdk-types": "^2.3.0",
    "@types/node": "~18.18.14",
    "dotenv": "^16.4.1",
    "ethers": "^5.7.2",
    "hardhat": "^2.22.10",
    "hardhat-deploy": "^0.12.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.5"
  }
}
