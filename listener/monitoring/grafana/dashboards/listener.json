          "expr": "listener_range_fetch_duration_seconds{chain_id=\"$chain_id\", quantile=\"0.95\"}",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "listener_range_fetch_duration_seconds{chain_id=\"$chain_id\", quantile=\"0.99\"}",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
