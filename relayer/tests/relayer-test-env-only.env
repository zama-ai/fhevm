# tests/relayer-test-env-only.env
# Env var overrides for testing that all config fields work via env vars.
# Overlaid on relayer-test-config.yaml as the YAML base (same as K8s deployment).
#
# IMPORTANT: Values here intentionally differ from relayer-test-config.yaml
# so the test can verify env vars actually override the YAML base.
#
# All Vec fields use indexed env vars (__0__, __1__) with the generic
# deserialize_vec_from_map_or_seq deserializer.

# Host chains (YAML: chain_id=8009, url=http://localhost:8545)
APP_HOST_CHAINS__0__CHAIN_ID=99999
APP_HOST_CHAINS__0__URL=http://env-override:8545
APP_HOST_CHAINS__0__ACL_ADDRESS=0x339EBB773A9bC1deCFfD5ef4BC7c907e26C1f836

# Gateway - blockchain RPC (YAML: chain_id=654321)
APP_GATEWAY__BLOCKCHAIN_RPC__HTTP_URL=http://env-override:8757
APP_GATEWAY__BLOCKCHAIN_RPC__READ_HTTP_URL=http://env-override:8757
APP_GATEWAY__BLOCKCHAIN_RPC__CHAIN_ID=111111

# Gateway - listener pool (YAML: 3 subscription listeners)
APP_GATEWAY__LISTENER_POOL__LISTENERS__0__TYPE=polling
APP_GATEWAY__LISTENER_POOL__LISTENERS__0__URL=http://env-override:1111
APP_GATEWAY__LISTENER_POOL__LISTENERS__1__TYPE=subscription
APP_GATEWAY__LISTENER_POOL__LISTENERS__1__URL=ws://env-override:2222

# Gateway - tx engine signer
APP_GATEWAY__TX_ENGINE__SIGNER__TYPE=private_key
APP_GATEWAY__TX_ENGINE__SIGNER__PRIVATE_KEY=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Gateway - contracts (YAML: threshold=9)
APP_GATEWAY__CONTRACTS__DECRYPTION_ADDRESS=0xB8Ae44365c45A7C5256b14F607CaE23BC040c354
APP_GATEWAY__CONTRACTS__INPUT_VERIFICATION_ADDRESS=0xE61cff9C581c7c91AEF682c2C10e8632864339ab
APP_GATEWAY__CONTRACTS__USER_DECRYPT_SHARES_THRESHOLD=5

# Retry-after backoff intervals (YAML: 5 intervals with different values)
APP_HTTP__RETRY_AFTER__COPRO_KMS_BACKOFF_INTERVALS__0__ELAPSED_THRESHOLD_SECS=0
APP_HTTP__RETRY_AFTER__COPRO_KMS_BACKOFF_INTERVALS__0__RETRY_INTERVAL_SECS=2
APP_HTTP__RETRY_AFTER__COPRO_KMS_BACKOFF_INTERVALS__1__ELAPSED_THRESHOLD_SECS=30
APP_HTTP__RETRY_AFTER__COPRO_KMS_BACKOFF_INTERVALS__1__RETRY_INTERVAL_SECS=5

# Metrics histogram buckets (indexed env vars, YAML has different values)
APP_METRICS__QUERY_DURATION_HISTOGRAM_BUCKET__0=0.01
APP_METRICS__QUERY_DURATION_HISTOGRAM_BUCKET__1=0.05
APP_METRICS__QUERY_DURATION_HISTOGRAM_BUCKET__2=0.1
APP_METRICS__REQUEST_STATUS_DURATION_HISTOGRAM_BUCKET__0=0.5
APP_METRICS__REQUEST_STATUS_DURATION_HISTOGRAM_BUCKET__1=1.0
APP_METRICS__REQUEST_STATUS_DURATION_HISTOGRAM_BUCKET__2=5.0
APP_METRICS__TRANSACTION_DURATION_SECS_HISTOGRAM_BUCKET__0=0.1
APP_METRICS__TRANSACTION_DURATION_SECS_HISTOGRAM_BUCKET__1=0.5
APP_METRICS__TRANSACTION_DURATION_SECS_HISTOGRAM_BUCKET__2=1.0
APP_METRICS__RETRY_AFTER_RAW_ETA_HISTOGRAM_BUCKET__0=1
APP_METRICS__RETRY_AFTER_RAW_ETA_HISTOGRAM_BUCKET__1=5
APP_METRICS__RETRY_AFTER_RAW_ETA_HISTOGRAM_BUCKET__2=10
APP_HTTP__METRICS__HISTOGRAM_BUCKETS__0=0.01
APP_HTTP__METRICS__HISTOGRAM_BUCKETS__1=0.05
APP_HTTP__METRICS__HISTOGRAM_BUCKETS__2=0.1

# Key URLs
APP_KEYURL__FHE_PUBLIC_KEY__DATA_ID=env-override-key-id
APP_KEYURL__FHE_PUBLIC_KEY__URL=http://env-override:3001/publicKey.bin
APP_KEYURL__CRS__DATA_ID=env-override-crs-id
APP_KEYURL__CRS__URL=http://env-override:3001/crs2048.bin

# Storage (YAML: localhost:5433)
APP_STORAGE__SQL_DATABASE_URL=postgresql://postgres:postgres@env-override:5433/relayer_db
