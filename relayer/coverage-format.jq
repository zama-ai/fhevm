"FILE\tCOVERAGE",
"─────────────────────────────────────────────────────────────────────────────",
(.data[0].files[] | "\(.filename | capture("(?<p>src/.*)") | .p)\t\(.summary.lines.percent * 100 | round | . / 100)%"),
"─────────────────────────────────────────────────────────────────────────────",
"TOTAL\t\(.data[0].totals.lines.percent * 100 | round | . / 100)%"