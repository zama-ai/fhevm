# Network configuration
APP_NETWORKS__ROLLUP__WS_URL=ws://localhost:8757
APP_NETWORKS__ROLLUP__HTTP_URL=http://localhost:8757
APP_NETWORKS__ROLLUP__CHAIN_ID=654321
APP_NETWORKS__ROLLUP__RETRY_DELAY=1000
APP_NETWORKS__ROLLUP__MAX_RECONNECTION_ATTEMPTS=3

# Key URL configuration
APP_KEYURL__FHE_PUBLIC_KEY__DATA_ID=fhe-public-key-data-id
APP_KEYURL__FHE_PUBLIC_KEY__URL=http://0.0.0.0:3001/publicKey.bin
APP_KEYURL__CRS__DATA_ID=crs-data-id
APP_KEYURL__CRS__URL=http://0.0.0.0:3001/crs2048.bin

# Transaction configuration
APP_TRANSACTION__PRIVATE_KEY_GATEWAY_ENV=GATEWAY_PRIVATE_KEY
APP_TRANSACTION__GAS_LIMIT=150000
APP_TRANSACTION__MAX_PRIORITY_FEE=2000000000
APP_TRANSACTION__TIMEOUT_SECS=30
APP_TRANSACTION__CONFIRMATIONS=1

APP_TRANSACTION__RETRY__MAX_ATTEMPTS=3
APP_TRANSACTION__RETRY__BASE_DELAY_SECS=2
APP_TRANSACTION__RETRY__MAX_DELAY_SECS=60

APP_TRANSACTION__CIPHERTEXT_CHECK_RETRY__MAX_ATTEMPTS=75
APP_TRANSACTION__CIPHERTEXT_CHECK_RETRY__BASE_DELAY_SECS=3
APP_TRANSACTION__CIPHERTEXT_CHECK_RETRY__MAX_DELAY_SECS=225

# Contract addresses
APP_CONTRACTS__DECRYPTION_ADDRESS=0x2Fb4341027eb1d2aD8B5D9708187df8633cAFA92
APP_CONTRACTS__INPUT_VERIFICATION_ADDRESS=0x05fD9B5EFE0a996095f42Ed7e77c390810CF660c

# Actual private keys (do not commit to version control)
GATEWAY_PRIVATE_KEY=your_gateway_private_key_here
