{
  "name": "@fhevm/local-cli",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "compat-smoke": "bun run src/compat/smoke.ts",
    "test": "bun test src",
    "test:e2e:harness": "bun test e2e/harness",
    "test:e2e": "bun test e2e/scenarios",
    "test:demo": "bun test demo",
    "demo:seed": "bun run demo/seed.ts",
    "demo:faucet": "bun run demo/faucet-server.ts",
    "demo:check-cors": "bun run demo/checkBrowserReality.ts",
    "demo:smoke": "RUN_DEMO_SCENARIOS=1 bun test e2e/scenarios/deposit-arc.scenario.test.ts",
    "demo:smoke-boundary": "RUN_DEMO_SCENARIOS=1 bun test e2e/scenarios/deposit-arc-boundary.scenario.test.ts",
    "start": "bun run src/cli.ts"
  },
  "dependencies": {
    "@fhevm/sdk": "file:../../sdk/js-sdk/src",
    "@solana/kit": "6.10.0",
    "citty": "^0.1.6",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "bun-types": "1.3.10",
    "typescript": "^5.9.2"
  }
}
