# Solana ACL MMR proof service (standalone; RFC-024 / #1682).
# Overrides the mounted config/app.yaml defaults for docker compose.
SOLANA_PROOF__SERVER__BIND_ADDRESS=0.0.0.0:8088
SOLANA_PROOF__DATABASE__CONNECTION_STRING=postgres://postgres:postgres@solana-proof-db:5432/solana_proof_service
SOLANA_PROOF__DATABASE__MAX_CONNECTIONS=10
# Filled by generate/env.ts when a Solana host chain is present.
SOLANA_PROOF__SOLANA__PROGRAM_ID=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA
SOLANA_PROOF__SOLANA__RPC_URL=http://host.docker.internal:8899
SOLANA_PROOF__YELLOWSTONE__GRPC_URL=http://host.docker.internal:10000
SOLANA_PROOF__READINESS__MAX_INGEST_SILENCE_SECS=60
# Required for history_complete / proof readiness. Local validator is always
# `--reset`, so genesis slot 0 is the deterministic Bootstrap A boundary.
# Non-reset / shared validators must set this to the ACL history start slot.
SOLANA_PROOF__RECOVERY__BOOTSTRAP_SLOT=0
SOLANA_PROOF__RECOVERY__MAX_SLOTS_PER_ATTEMPT=256
SOLANA_PROOF__RECOVERY__MAX_BLOCKS_PER_ATTEMPT=128
