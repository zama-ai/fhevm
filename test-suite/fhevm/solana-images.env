# Single source of truth for the Solana PoC image tags (FI#1546).
#
# Consumed by both shell (solana/scripts/poc/clean-e2e.sh sources this file) and TS
# (src/solana/images.ts parses it) so the kms-core tag cannot drift across call sites.
#
# CORE_VERSION (the kms-core server image) and KMS_BUILT_FROM (the commit the vendored TKMS WASM
# client was built from) must be LINK-COMPATIBLE — same Solana de-signcryption wire format and
# `compute_link_solana` digest — not necessarily the same commit. The current pair (kms-core image
# `solana-ud-c57f52f-fix` / WASM `07be70ab`) is verified compatible by the full-vertical e2e.
# (`-fix` is the corrected rebuild of the c57f52f-pinned kms-core; the bare tag is the pre-fix
# image and must NOT be used.)
CORE_VERSION=solana-ud-c57f52f-fix
CONNECTOR_GW_LISTENER_VERSION=solana-ud
CONNECTOR_KMS_WORKER_VERSION=solana-ud-v2
RELAYER_IMAGE_REPOSITORY=solana-e2e/relayer
RELAYER_VERSION=solana-ud
