# Single source of truth for the Solana PoC image tags (FI#1546).
#
# Consumed by both shell (solana/scripts/poc/clean-e2e.sh sources this file) and TS
# (src/solana/images.ts parses it) so the kms-core tag cannot drift across call sites.
#
# CORE_VERSION must match the kms commit the vendored TKMS WASM was built from — keep it in
# step with KMS_BUILT_FROM stamped by regen-tkms-wasm.sh. (`-fix` is the corrected rebuild of
# the c57f52f-pinned kms-core; the bare tag is the pre-fix image and must NOT be used.)
CORE_VERSION=solana-ud-c57f52f-fix
CONNECTOR_GW_LISTENER_VERSION=solana-ud
CONNECTOR_KMS_WORKER_VERSION=solana-ud-v2
RELAYER_IMAGE_REPOSITORY=solana-e2e/relayer
RELAYER_VERSION=solana-ud
