apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: coprocessor-host-listener
    app.kubernetes.io/name: coprocessor-0-host-listener
  name: coprocessor-0-host-listener
spec:
  replicas: 1
  selector:
    matchLabels:
      app: coprocessor-host-listener
  strategy:
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: coprocessor-host-listener
        app.kubernetes.io/name: coprocessor-0-host-listener
    spec:
      imagePullSecrets:
        - name: registry-credentials
      restartPolicy: Always
      containers:
        - name: coprocessor-host-listener
          image: ghcr.io/zama-ai/fhevm/coprocessor/host-listener:v0.11.0
          command: ["host_listener"]
          args:
            - --database-url=$(DATABASE_URL)
            - --url=$(ETHEREUM_RPC_URL)
            - --acl-contract-address=$(ACL_CONTRACT_ADDRESS)
            - --tfhe-contract-address=$(FHEVM_EXECUTOR_CONTRACT_ADDRESS)
            - --health-port=8080
          env:
            - name: DATABASE_URL
              value: "postgresql://coprocessor:coprocessor@db:5432/coprocessor"
            - name: ETHEREUM_RPC_URL
              value: "ws://anvil-node-eth:8546"
            - name: ACL_CONTRACT_ADDRESS
              value: "map[valueFrom:map[configMapKeyRef:map[key:acl.address name:sc-addresses]]]"
            - name: FHEVM_EXECUTOR_CONTRACT_ADDRESS
              value: "map[valueFrom:map[configMapKeyRef:map[key:fhevm_executor.address name:sc-addresses]]]"
          ports:
            - name: healthcheck
              containerPort: 8080
              protocol: TCP
            - name: metrics
              containerPort: 9100
              protocol: TCP
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi---
