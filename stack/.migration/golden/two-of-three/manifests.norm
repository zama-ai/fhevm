metadata:
  name: host-contracts-config-writer
  namespace: default
apiVersion: v1
kind: ServiceAccount
metadata:
  name: listener
  labels:
    app.kubernetes.io/managed-by: Helm
    app.kubernetes.io/part-of: listener
automountServiceAccountToken: true
kind: Role
apiVersion: rbac.authorization.k8s.io/v1
metadata:
  name: host-contracts-config-writer
  namespace: default
rules:
  - apiGroups: [""]
    resources: ["configmaps"]
    verbs: ["get", "watch", "list", "create", "patch"]
kind: RoleBinding
apiVersion: rbac.authorization.k8s.io/v1
metadata:
  name: host-contracts-config-writer
  namespace: default
subjects:
  - kind: ServiceAccount
    name: host-contracts-config-writer
    namespace: default
roleRef:
  kind: Role
  name: host-contracts-config-writer
  apiGroup: rbac.authorization.k8s.io
