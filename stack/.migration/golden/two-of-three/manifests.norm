            periodSeconds: 10
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: anvil-node-anvil-node
spec:
  serviceName: anvil-node-anvil-node
  replicas: 1
  selector:
    matchLabels:
      app: anvil-node-anvil-node
  template:
    metadata:
      labels:
        app: anvil-node-anvil-node
    spec:
      containers:
        - name: anvil-node
          image: ghcr.io/foundry-rs/foundry:stable
          command: ["anvil"]
          env:
            - name: MNEMONIC
              value: 
          args:
            - "--block-time"
            - "0.5"
            - "--host"
            - "0.0.0.0"
            - "--port"
            - "8545"
            - "--chain-id"
            - "12345"
            - "--accounts"
            - "10"
            - "--mnemonic"
            - "$(MNEMONIC)"
          ports:
            - containerPort: 8545
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
          volumeMounts:
          - name: anvil-chain-data
            mountPath: /home/foundry/.foundry/anvil
  volumeClaimTemplates:
  - metadata:
      name: anvil-chain-data
    spec:
      accessModes: [ "ReadWriteOnce" ]
      resources:
        requests:
          storage: 1Gi
apiVersion: batch/v1
kind: Job
metadata:
  labels:
    app: fhevm-sc-deploy
    app.kubernetes.io/name: host-contracts-deploy
  name: host-contracts-deploy
spec:
  backoffLimit: 0
  template:
    metadata:
      annotations:
      labels:
    spec:
      serviceAccountName: host-contracts-config-writer
      securityContext:
        fsGroup: 10001
        runAsNonRoot: true
        runAsUser: 10000
      containers:
      - name: deploy-smart-contracts
        command: [ "/app/deploy-contracts.sh" ]
        image: ghcr.io/zama-ai/fhevm/host-contracts:v0.13.0
        env:
          - name: DEPLOYED_SMART_CONTRACTS_VERSION
            valueFrom:
              configMapKeyRef:
                name: sc-addresses
                key: contracts.version
                optional: true
          - name: MANIFEST_DEFAULT_DIR
            value: "/app/addresses/.openzeppelin"
          
          - name: DEPLOYER_PRIVATE_KEY
            value: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
          - name: NUM_KMS_NODES
            value: "3"
          - name: KMS_TX_SENDER_ADDRESS_0
            value: 0xTODO_KMS_TX_SENDER_0
          - name: KMS_SIGNER_ADDRESS_0
            value: 0xTODO_KMS_SIGNER_0
          - name: KMS_NODE_IP_0
            value: kms-core-0.default.svc.cluster.local
          - name: KMS_NODE_STORAGE_URL_0
            value: http://kms-core-0.default.svc.cluster.local:9000
          - name: KMS_TX_SENDER_ADDRESS_1
            value: 0xTODO_KMS_TX_SENDER_1
          - name: KMS_SIGNER_ADDRESS_1
            value: 0xTODO_KMS_SIGNER_1
          - name: KMS_NODE_IP_1
            value: kms-core-1.default.svc.cluster.local
          - name: KMS_NODE_STORAGE_URL_1
            value: http://kms-core-1.default.svc.cluster.local:9000
          - name: KMS_TX_SENDER_ADDRESS_2
            value: 0xTODO_KMS_TX_SENDER_2
          - name: KMS_SIGNER_ADDRESS_2
            value: 0xTODO_KMS_SIGNER_2
          - name: KMS_NODE_IP_2
            value: kms-core-2.default.svc.cluster.local
          - name: KMS_NODE_STORAGE_URL_2
            value: http://kms-core-2.default.svc.cluster.local:9000
          - name: PUBLIC_DECRYPTION_THRESHOLD
            value: "2"
          - name: USER_DECRYPTION_THRESHOLD
            value: "2"
          - name: KMS_GEN_THRESHOLD
            value: "2"
          - name: MPC_THRESHOLD
            value: "2"
          - name: NUM_COPROCESSORS
            value: "3"
          - name: COPROCESSOR_THRESHOLD
            value: "2"
          - name: COPROCESSOR_SIGNER_ADDRESS_0
            value: 0xTODO_COPROCESSOR_SIGNER_0
          - name: COPROCESSOR_SIGNER_ADDRESS_1
            value: 0xTODO_COPROCESSOR_SIGNER_1
          - name: COPROCESSOR_SIGNER_ADDRESS_2
            value: 0xTODO_COPROCESSOR_SIGNER_2
          - name: CHAIN_ID_GATEWAY
            value: "54321"
          - name: DECRYPTION_ADDRESS
            value: 0xTODO_DECRYPTION_ADDRESS
          - name: INPUT_VERIFICATION_ADDRESS
            value: 0xTODO_INPUT_VERIFICATION_ADDRESS
          - name: NUM_PAUSERS
            value: "6"
          - name: PAUSER_ADDRESS_0
            value: 0xTODO_KMS_TX_SENDER_0
          - name: PAUSER_ADDRESS_1
            value: 0xTODO_KMS_TX_SENDER_1
          - name: PAUSER_ADDRESS_2
            value: 0xTODO_KMS_TX_SENDER_2
          - name: PAUSER_ADDRESS_3
            value: 0xTODO_COPROCESSOR_TX_SENDER_0
          - name: PAUSER_ADDRESS_4
            value: 0xTODO_COPROCESSOR_TX_SENDER_1
          - name: PAUSER_ADDRESS_5
            value: 0xTODO_COPROCESSOR_TX_SENDER_2
        volumeMounts:
          - mountPath: /app/deploy-contracts.sh
            subPath: deploy-contracts.sh
            name: config
          - mountPath: /app/upgrade-contracts.sh
            subPath: upgrade-contracts.sh
            name: config
          - mountPath: /app/addresses
            name: persistence
        resources:
          requests:
            cpu: 100m
            memory: 256Mi
          limits:
            cpu: 500m
            memory: 512Mi
      volumes:
      - name: config
        configMap:
          name: host-contracts-config
          defaultMode: 0755
      - name: persistence
        persistentVolumeClaim:
          claimName: host-contracts
      restartPolicy: Never
      imagePullSecrets:
        - name: registry-credentials
apiVersion: batch/v1
kind: Job
metadata:
  name: coprocessor-0-db-migration-1
  labels:
    app: coprocessor-db-migration
    app.kubernetes.io/name: coprocessor-0-db-migration
  namespace: default
spec:
  backoffLimit: 3
  template:
    metadata:
      labels:
        app: coprocessor-db-migration
        app.kubernetes.io/name: coprocessor-0-db-migration
    spec:
      imagePullSecrets:
        - name: registry-credentials
      restartPolicy: Never
      containers:
      - name: db-migration
        image: ghcr.io/zama-ai/fhevm/coprocessor/db-migration:v0.11.0
        command: ["/initialize_db.sh"]
        env:
          - name: DATABASE_URL
            value: "postgresql://coprocessor:coprocessor@db:5432/coprocessor"
          - name: HOST_CHAINS_COUNT
            value: "2"
          - name: HOST_CHAIN_0_ID
            value: "31337"
          - name: HOST_CHAIN_0_NAME
            value: "ethereum"
          - name: HOST_CHAIN_0_ACL
            value: "map[valueFrom:map[configMapKeyRef:map[key:acl.address name:sc-addresses]]]"
          - name: HOST_CHAIN_1_ID
            value: "80002"
          - name: HOST_CHAIN_1_NAME
            value: "polygon"
          - name: HOST_CHAIN_1_ACL
            value: "0xTODO_POLYGON_ACL_ADDRESS"
        resources:
          requests:
            cpu: 100m
            memory: 256Mi
          limits:
            cpu: 500m
            memory: 512Mi
