        - name: registry-credentials
      restartPolicy: Always
      containers:
        - name: kms-connector-tx-sender
          image: ghcr.io/zama-ai/fhevm/kms-connector/tx-sender:v0.10.0
          env:
            - name: KMS_CONNECTOR_DATABASE_URL
              value: "postgresql://kms-connector:kms-connector@db:5432/kms-connector"
            - name: KMS_CONNECTOR_GATEWAY_URL
              value: "http://gateway-node:8546"
            - name: KMS_CONNECTOR_GATEWAY_CHAIN_ID
              value: "54321"
            - name: KMS_CONNECTOR_DECRYPTION_CONTRACT__ADDRESS
              value: "0xTODO_DECRYPTION_ADDRESS"
            - name: KMS_CONNECTOR_GATEWAY_CONFIG_CONTRACT__ADDRESS
              value: "0xTODO_GATEWAY_CONFIG_ADDRESS"
            - name: KMS_CONNECTOR_KMS_GENERATION_CONTRACT__ADDRESS
              value: "0xTODO_KMS_GENERATION_ADDRESS"
            - name: KMS_CONNECTOR_ETHEREUM_URL
              value: "http://anvil-node-eth:8545"
            - name: KMS_CONNECTOR_ETHEREUM_CHAIN_ID
              value: "31337"
            - name: KMS_CONNECTOR_KMS_VERIFIER_ADDRESS
              value: "0xTODO_KMS_VERIFIER_ADDRESS"
            - name: KMS_CONNECTOR_PRIVATE_KEY
              valueFrom:
                secretKeyRef:
                  name: "kms-connector-tx-sender"
                  key: "kms-wallet"
            - name: OTEL_EXPORTER_OTLP_ENDPOINT
              value: http://otel-deployment-opentelemetry-collector.observability.svc.cluster.local:4317
