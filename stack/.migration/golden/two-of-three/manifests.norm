apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: coprocessor-gw-listener
    app.kubernetes.io/name: coprocessor-0-gw-listener
  name: coprocessor-0-gw-listener
spec:
  replicas: 1
  selector:
    matchLabels:
      app: coprocessor-gw-listener
  strategy:
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: coprocessor-gw-listener
        app.kubernetes.io/name: coprocessor-0-gw-listener
    spec:
      imagePullSecrets:
        - name: registry-credentials
      restartPolicy: Always
      containers:
        - name: coprocessor-gw-listener
          image: ghcr.io/zama-ai/fhevm/coprocessor/gw-listener:v0.12.0
          command: ["gw_listener"]
          args:
            - --database-url=$(DATABASE_URL)
            - --gw-url=$(GATEWAY_URL)
            - --input-verification-address=$(INPUT_VERIFICATION_ADDRESS)
            - --ciphertext-commits-address=$(CIPHERTEXT_COMMITS_ADDRESS)
            - --gateway-config-address=$(GATEWAY_CONFIG_ADDRESS)
            - --health-check-port=8080
            - --metrics-addr=0.0.0.0:9100
          env:
            - name: DATABASE_URL
              value: "postgresql://coprocessor:coprocessor@db:5432/coprocessor"
            - name: GATEWAY_URL
              value: "http://gateway-node:8546"
            - name: INPUT_VERIFICATION_ADDRESS
              value: "0xTODO_INPUT_VERIFICATION_ADDRESS"
            - name: CIPHERTEXT_COMMITS_ADDRESS
              value: "0xTODO_CIPHERTEXT_COMMITS_ADDRESS"
            - name: GATEWAY_CONFIG_ADDRESS
              value: "0xTODO_GATEWAY_CONFIG_ADDRESS"
          ports:
            - name: healthcheck
              containerPort: 8080
              protocol: TCP
            - name: metrics
              containerPort: 9100
              protocol: TCP
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
