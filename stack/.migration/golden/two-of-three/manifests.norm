              value: "0xTODO_CIPHERTEXT_COMMITS_ADDRESS"
            - name: TX_SENDER_PRIVATE_KEY
              value: "0xTODO_COPROCESSOR_TX_SENDER_PRIVATE_KEY"
          ports:
            - name: healthcheck
              containerPort: 8080
              protocol: TCP
            - name: metrics
              containerPort: 9100
              protocol: TCP
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
