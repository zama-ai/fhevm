apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: kms-connector-gw-listener
    app.kubernetes.io/name: kms-connector-kms-connector-gw-listener
  name: kms-connector-kms-connector-gw-listener
spec:
  replicas: 1
  selector:
    matchLabels:
      app: kms-connector-gw-listener
  strategy:
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: kms-connector-gw-listener
        app.kubernetes.io/name: kms-connector-kms-connector-gw-listener
    spec:
      imagePullSecrets:
        - name: registry-credentials
      restartPolicy: Always
      containers:
        - name: kms-connector-gw-listener
          image: ghcr.io/zama-ai/fhevm/kms-connector/gw-listener:v0.10.0
          env:
            - name: KMS_CONNECTOR_DATABASE_URL
              value: "postgresql://kms-connector:kms-connector@db:5432/kms-connector"
            - name: KMS_CONNECTOR_GATEWAY_URL
              value: "http://gateway-node:8546"
            - name: KMS_CONNECTOR_GATEWAY_CHAIN_ID
              value: "54321"
            - name: KMS_CONNECTOR_DECRYPTION_CONTRACT__ADDRESS
              value: "0xTODO_DECRYPTION_ADDRESS"
            - name: KMS_CONNECTOR_GATEWAY_CONFIG_CONTRACT__ADDRESS
              value: "0xTODO_GATEWAY_CONFIG_ADDRESS"
            - name: KMS_CONNECTOR_KMS_GENERATION_CONTRACT__ADDRESS
              value: "0xTODO_KMS_GENERATION_ADDRESS"
            - name: KMS_CONNECTOR_ETHEREUM_URL
              value: "http://anvil-node-eth:8545"
            - name: KMS_CONNECTOR_ETHEREUM_CHAIN_ID
              value: "31337"
            - name: KMS_CONNECTOR_KMS_VERIFIER_ADDRESS
              value: "0xTODO_KMS_VERIFIER_ADDRESS"
          ports:
            - name: monitoring
              containerPort: 9100
              protocol: TCP
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
          livenessProbe:
            httpGet:
              path: /healthz
              port: monitoring
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /healthz
              port: monitoring
            initialDelaySeconds: 5
            periodSeconds: 10
apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: kms-connector-kms-worker
